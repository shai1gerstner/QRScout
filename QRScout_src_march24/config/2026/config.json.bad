{
    "title": "QRScout",
    "page_title": "FRC-Rebuilt",
    "delimiter": "\t",
    "teamNumber": 1024,
    "confVersion": "2026Feb09",
    "floatingField": {
        "show": false,
        "codeValue": "teamNumber"
    },
    "theme": {
